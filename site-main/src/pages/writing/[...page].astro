---
// src/pages/blog/[...page].astro
import type { GetStaticPaths, Page } from 'astro'
import type { WritingCollectionPost } from '../../lib/sanity'

import { Paginator, PostPreview } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

// Import our new Sanity helper
import { getSanityPosts } from '../../lib/sanity'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const collections = await getSanityPosts()

  const allTags = collections.flatMap((post: any) => post.data.tags)
  const uniqueTags = [...new Set(allTags)] as string[]
  
  const collectionsCount = collections.length

  return paginate(collections, {
    pageSize: config.content.blogPageSize,
    props: { uniqueTags, collectionsCount }
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<WritingCollectionPost>
  uniqueTags: string[]
  collectionsCount: number
}

const { page, uniqueTags, collectionsCount } = Astro.props

const meta = {
  description: 'Interesting things I want to share.',
  title: 'Writing'
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous Articles`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next Articles →`,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>Writing</h1>
    </div>
    {
      page.data.length === 0 ? (
        <p>No articles yet.</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label='Articles list' class='animate' id='content'>
            {/* header */}
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                Page {page.currentPage} - Showing {page.data.length} of {collectionsCount} articles
              </span>
              <a aria-label='View all articles by years' href='/archives' data-astro-prefetch>
                View all articles by years →
              </a>
            </div>
            {/* posts */}
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                // @ts-ignore - The mapped object shape matches what PostPreview needs
                <PostPreview {post} detailed />
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </section>

          {/* sidebar */}
          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-semibold'>
                <Icon name='tag-2' class='me-2' />
                Tags
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {uniqueTags.map((tag) => (
                  <li>
                    <Button title={tag} href={`/tags/${tag}`} variant='pill' />
                  </li>
                ))}
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a aria-label='View article categories' href='/tags' data-astro-prefetch>
                  View all →
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>